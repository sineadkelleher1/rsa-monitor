# ──────────────────────────────────────────────
# RSA Slot Monitor — Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# Server
PORT=3001
ALLOWED_ORIGIN=https://claude.ai

# Scraper
POLL_INTERVAL_MS=25000

# Email alerts (Gmail example — use an App Password, not your account password)
# Create App Password: https://myaccount.google.com/apppasswords
ALERT_EMAIL_TO=your@email.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-16-char-app-password

# Optional: MyRoadSafety login (only needed if site requires login to view slots)
# RSA_LOGIN_EMAIL=your@email.com
# RSA_LOGIN_PASSWORD=yourpassword
